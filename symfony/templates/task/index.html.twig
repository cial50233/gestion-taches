{% extends 'base.html.twig' %}

{% block title %}
	Liste des tâches
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<h1>
			Liste des tâches ({{ taskCount }}
			tâche{{ taskCount > 1 ? 's' : '' }})
		</h1>


		<p>
			<a href="{{ path('app_task_new') }}" class="btn btn-primary">
				Nouvelle tâche
			</a>
		</p>


		{% for task in tasks %}
			<div class="card mb-3">
				<div class="card-body">

					<h5 class="card-title">
						{{ task.name }}

						{% if task.completed %}
							✅
						{% else %}
							❌
						{% endif %}
					</h5>
					<p class="text-muted small mb-2">
						📅 Créée le
						{{ task.createdAt|date('d/m/Y à H:i') }}
					</p>

					<div class="mt-3">

						<a href="{{ path('app_task_edit', {'id': task.id}) }}" class="btn btn-warning btn-sm">
							Modifier
						</a>

						<a href="{{ path('app_task_delete', {'id': task.id}) }}" class="btn btn-danger btn-sm">
							Supprimer
						</a>

						{% if not task.completed %}

							<a href="{{ path('app_task_complete', {'id': task.id}) }}" class="btn btn-success btn-sm">
								Terminer
							</a>

						{% endif %}

					</div>


				</div>
			</div>


		{% else %}
			<div class="alert alert-info">
				Aucune tâche pour le moment
			</div>
		{% endfor %}

	</div>
{% endblock %}
